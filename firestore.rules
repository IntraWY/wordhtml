rules_version = '2';

// Recommended rules for wordhtml after Firebase Auth + per-user paths are implemented.
// CURRENT APP: may still use legacy global `templates` — adjust rules to match your deployment.
//
// Deploy: firebase deploy --only firestore:rules
//
// See docs/firebase-cloud-sync-design.md

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Target (per-user) layout ---
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /templates/{templateId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /snapshots/{snapshotId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // --- Legacy global templates (migration source only) ---
    // Signed-in users may read legacy docs once to copy into users/{uid}/templates.
    // Writes to legacy path should be disabled in production after migration.
    match /templates/{templateId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
