rules_version = '2';

// Production rules for wordhtml. Firebase Auth (Google) + per-user paths are
// implemented: templates live at users/{uid}/templates and history snapshots at
// users/{uid}/snapshots. The app gates all cloud WRITES on sign-in
// (see SignInRequiredError in src/store/templateStore.ts), so the legacy global
// `templates` collection is kept read-only purely as a one-time migration source.
//
// Deploy: firebase deploy --only firestore:rules
//
// See docs/firebase-cloud-sync-design.md

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Target (per-user) layout ---
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /templates/{templateId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /snapshots/{snapshotId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // --- Legacy global templates (migration source only) ---
    // Signed-in users may read legacy docs once to copy into users/{uid}/templates.
    // Writes to legacy path should be disabled in production after migration.
    match /templates/{templateId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
